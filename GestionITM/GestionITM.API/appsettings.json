{
    "ConnectionStrings": {
        "DefaultConnection": "Server=Laptop-de-juli\\SQLEXPRESS;Database=GestionITMDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True"

    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",

            {
                "Serilog": {
                    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
                    "MinimumLevel": {
                        "Default": "Information",
                        "Override": {
                            "Microsoft": "Warning",
                            "System": "Warning",
                            "Microsoft.Hosting.Lifetime": "Information"
                        }
                    },
                    "Enrich": [ "FromLogContext", "WithMachineName" ],
                    "WriteTo": [
                        { "Name": "Console" },
                        {
                            "Name": "File",
                            "Args": {
                                "path": "Logs/api-log-.txt",
                                "rollingInterval": "Day",
                                "retainedFileCountLimit": 7,
                                "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} <s:{SourceContext}>{NewLine}{Exception}"
                            }
                        }
                    ]
                },

                "AllowedHosts": "*",


                "Jwt": {
                    "Key": "Esta_Es_Una_Llave_Super_Secreta_Nivel_5_ITM_2026",
                    "Issuer": "GestionITMAPI",
                    "Audience": "EstudiantesITM"
                }

            }

        }
    }

}